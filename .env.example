# SlothFlix Configuration
# Copy this to .env and fill in your values

# Auth
AUTH_USER=admin
AUTH_PASS=slothflix

# Transmission RPC
TRANSMISSION_HOST=127.0.0.1
TRANSMISSION_PORT=9191
TRANSMISSION_RPC_USERNAME=admin
TRANSMISSION_RPC_PASSWORD=adminadmin

# OpenVPN (for transmission container)
OPENVPN_PROVIDER=PUREVPN
OPENVPN_USERNAME=your_openvpn_username
OPENVPN_PASSWORD=your_openvpn_password
OPENVPN_CONFIG=nl2-auto-tcp-qr

# Dynu DNS (for Traefik ACME)
DYNU_API_KEY=your_dynu_api_key

# SearXNG
SEARXNG_HOST=http://127.0.0.1:8080

# Paths
DOWNLOAD_DIR=/downloads
CACHE_DB_PATH=/app/data/cache.db
ROM_DIR=/data/roms

# Server
FLASK_PORT=8180

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=5597932516

# Token
TOKEN_EXPIRY_DAYS=7

# Public URL
APP_URL=https://slothitude.giize.com
